{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>HikaruEgashira/renovate",
    "github>aquaproj/aqua-renovate-config#2.12.0",
    "helpers:pinGitHubActionDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^renovate\\.json5?$"],
      "matchStrings": [
        "github>aquaproj/aqua-renovate-config#(?<currentValue>.+?)\""
      ],
      "depNameTemplate": "aquaproj/aqua-renovate-config",
      "datasourceTemplate": "github-releases"
    }
  ]
}
